// ─── Reset ────────────────────────────────────────────────────────────
*,
*::before,
*::after
  box-sizing border-box
  margin 0
  padding 0

html
  scroll-behavior smooth
  -webkit-text-size-adjust 100%

body
  font-family $font-sans
  background $gray-50
  color $dark
  line-height 1.5
  -webkit-font-smoothing antialiased
  -moz-osx-font-smoothing grayscale
  transition background-color .3s ease, color .3s ease

  &.dark
    background $dark
    color $gray-50

a
  color inherit
  text-decoration none

img,
svg
  display block
  max-width 100%

button
  font-family $font-sans

ul,
ol
  list-style none

// ─── Scrollbar ────────────────────────────────────────────────────────
::-webkit-scrollbar
  width 6px

::-webkit-scrollbar-track
  background $gray-100

  .dark &
    background $gray-900

::-webkit-scrollbar-thumb
  background $purple
  border-radius 3px

// ─── Focus ring ───────────────────────────────────────────────────────
:focus-visible
  outline 2px solid $purple
  outline-offset 2px
  border-radius 4px

// ─── Screen reader only ───────────────────────────────────────────────
.sr-only
  position absolute
  width 1px
  height 1px
  padding 0
  margin -1px
  overflow hidden
  clip rect(0,0,0,0)
  white-space nowrap
  border-width 0
// ─── Brand Colors ─────────────────────────────────────────────────────
$purple        = #6C5CE7
$purple-600    = #5B4DD6
$purple-700    = #4B3FBF
$purple-50     = #F0EEFF
$cyan          = #22D3EE
$cyan-600      = #0EA5C9
$orange        = #F59E0B
$red           = #EF4444
$dark          = #0F0F1A
$white         = #FFFFFF

// ─── Grays ────────────────────────────────────────────────────────────
$gray-900      = #1A1A2E
$gray-700      = #374151
$gray-500      = #6B7280
$gray-400      = #9CA3AF
$gray-300      = #D1D5DB
$gray-200      = #E5E7EB
$gray-100      = #F3F4F6
$gray-50       = #F9FAFB

// ─── Typography ───────────────────────────────────────────────────────
$font-sans     = 'Inter', system-ui, -apple-system, sans-serif

// ─── Spacing / Radius ─────────────────────────────────────────────────
$radius-sm     = 4px
$radius-md     = 8px
$radius-lg     = 12px
$radius-xl     = 16px
$radius-full   = 9999px

// ─── Shadows ──────────────────────────────────────────────────────────
$shadow-sm     = 0 1px 3px rgba(0,0,0,.08)
$shadow-md     = 0 4px 16px rgba(0,0,0,.10)
$shadow-purple = 0 4px 16px rgba(108,92,231,.35)

// ─── Transitions ──────────────────────────────────────────────────────
$transition        = all .25s ease
$transition-colors = color .2s ease, background-color .2s ease, border-color .2s ease

// ─── Breakpoints ──────────────────────────────────────────────────────
$bp-sm     = 640px
$bp-md     = 768px
$bp-lg     = 1024px
$bp-xl     = 1280px
// ─── Footer ───────────────────────────────────────────────────────────
.footer
  border-top 1px solid $gray-200
  background $gray-50

  .dark &
    border-top-color rgba($gray-700, .5)
    background $dark

  &__main
    container()
    padding-top 3.5rem
    padding-bottom 3.5rem

  &__grid
    display grid
    grid-template-columns 1fr
    gap 2.5rem

    @media (min-width: $bp-sm)
      grid-template-columns repeat(2, 1fr)

    @media (min-width: $bp-lg)
      grid-template-columns 2fr 1fr 1fr 1fr

  &__brand-logo
    margin-bottom .75rem

    img
      height 2rem
      width auto

  &__brand-desc
    font-size .875rem
    color $gray-500
    line-height 1.6
    max-width 20rem
    margin-bottom 1.25rem

  &__contact-list
    display flex
    flex-direction column
    gap .5rem
    margin-bottom 1.5rem

  &__contact-item
    display flex
    align-items center
    gap .5rem
    font-size .875rem
    color $gray-500

    a
      transition color .2s ease

      &:hover
        color $purple

  &__contact-icon
    color $purple
    flex-shrink 0
    font-size .875rem

  &__social
    display flex
    gap .75rem

  &__social-link
    width 2.25rem
    height 2.25rem
    border-radius $radius-full
    background $purple
    color $white
    display flex
    align-items center
    justify-content center
    font-size .875rem
    line-height 1
    transition $transition

    svg
      display block
      flex-shrink 0

    &:hover
      background $cyan
      color $white

  &__col-title
    font-size .75rem
    font-weight 700
    text-transform uppercase
    letter-spacing .08em
    color $dark
    margin-bottom 1rem

    .dark &
      color $white

  &__links
    display flex
    flex-direction column
    gap .625rem

  &__link
    font-size .875rem
    color $gray-500
    transition color .2s ease

    &:hover
      color $purple

  &__bottom
    border-top 1px solid $gray-200

    .dark &
      border-top-color rgba($white, .05)

  &__bottom-inner
    container()
    display flex
    flex-direction column
    align-items center
    gap .75rem
    padding-top 1.25rem
    padding-bottom 1.25rem

    @media (min-width: $bp-sm)
      flex-direction row
      justify-content space-between

  &__copy
    font-size .75rem
    color $gray-500

  &__legal
    display flex
    gap 1.25rem

  &__legal-link
    font-size .75rem
    color $gray-500
    transition color .2s ease

    &:hover
      color $purple

// ─── Why ADIPA ────────────────────────────────────────────────────────
.why
  background $white
  padding 5rem 0

  .dark &
    background $gray-900

  &__inner
    container()

  &__header
    text-align center
    margin-bottom 3rem

  &__grid
    display grid
    grid-template-columns 1fr
    gap 1.5rem

    @media (min-width: $bp-sm)
      grid-template-columns repeat(2, 1fr)

    @media (min-width: $bp-lg)
      grid-template-columns repeat(4, 1fr)

  &__card
    border-radius $radius-xl
    border 1px solid $gray-200
    background $gray-50
    padding 1.5rem
    transition $transition

    .dark &
      border-color rgba($gray-700, .6)
      background rgba($gray-900, .6)

    &:hover
      border-color rgba($purple, .3)
      box-shadow $shadow-md

  &__icon
    width 3rem
    height 3rem
    border-radius $radius-md
    background rgba($purple, .1)
    display flex
    align-items center
    justify-content center
    line-height 1
    margin-bottom 1rem
    font-size 1.5rem

  &__card-title
    font-weight 700
    color $dark
    margin-bottom .5rem

    .dark &
      color $white

  &__card-desc
    font-size .875rem
    line-height 1.6
    color $gray-500

    .dark &
      color $white

// ─── Testimonials ─────────────────────────────────────────────────────
.testimonials
  background $gray-50
  padding 5rem 0

  .dark &
    background rgba($gray-900, .5)

  &__inner
    container()

  &__header
    text-align center
    margin-bottom 3rem

  &__grid
    display grid
    grid-template-columns 1fr
    gap 1.5rem

    @media (min-width: $bp-sm)
      grid-template-columns repeat(2, 1fr)

    @media (min-width: $bp-lg)
      grid-template-columns repeat(3, 1fr)

  &__card
    border-radius $radius-xl
    background $white
    padding 1.5rem
    box-shadow $shadow-sm

    .dark &
      background $gray-900

  &__stars
    display flex
    gap .25rem
    margin-bottom 1rem
    font-size 1rem
    color $orange

  &__quote
    font-size .875rem
    line-height 1.7
    color $gray-700
    margin-bottom 1.25rem

    .dark &
      color $white

  &__author
    display flex
    align-items center
    gap .75rem

  &__avatar
    width 2.5rem
    height 2.5rem
    border-radius $radius-full
    background $purple
    color $white
    font-size .875rem
    font-weight 700
    flex-center()
    display flex
    flex-shrink 0

  &__name
    display block
    font-size .875rem
    font-weight 700
    color $dark
    font-style normal

    .dark &
      color $white

  &__role
    font-size .75rem
    color $gray-500

    .dark &
      color $white
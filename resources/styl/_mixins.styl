container()
  width 100%
  max-width 1280px
  margin-left auto
  margin-right auto
  padding-left 1rem
  padding-right 1rem

  @media (min-width: $bp-sm)
    padding-left 1.5rem
    padding-right 1.5rem

  @media (min-width: $bp-lg)
    padding-left 2rem
    padding-right 2rem

flex-center()
  display flex
  align-items center
  justify-content center

flex-between()
  display flex
  align-items center
  justify-content space-between

btn-base()
  display inline-flex
  align-items center
  justify-content center
  font-weight 600
  font-family $font-sans
  text-decoration none
  transition $transition
  cursor pointer
  border none
  border-radius 7px

card-hover()
  transition $transition

  &:hover
    transform translateY(-4px)
    box-shadow $shadow-lg

gradient-text()
  background linear-gradient(135deg, $purple 0%, $cyan 100%)
  -webkit-background-clip text
  -webkit-text-fill-color transparent
  background-clip text
// ─── Hero ─────────────────────────────────────────────────────────────
.hero
  position relative
  overflow hidden
  background linear-gradient(135deg, #6C5CE7 0%, #8B5CF6 50%, #7C3AED 100%)
  padding-top 3rem

  &__blobs
    pointer-events none

  &__blob
    position absolute
    border-radius $radius-full
    filter blur(80px)

    &--1
      top -6rem
      right -6rem
      width 24rem
      height 24rem
      background rgba($white, .05)

    &--2
      bottom -6rem
      left -6rem
      width 24rem
      height 24rem
      background rgba($cyan, .1)

  &__inner
    container()
    position relative
    z-index 10
    padding-bottom 4rem

  &__trust
    display flex
    flex-wrap wrap
    align-items center
    justify-content center
    gap 1rem 1.5rem
    color rgba($white, .7)
    font-size .875rem
    margin-bottom 1.5rem

  &__trust-item
    display flex
    align-items center
    gap .375rem

  &__trust-divider
    width 1px
    height .75rem
    background rgba($white, .3)
    display none

    @media (min-width: $bp-sm)
      display block

  &__heading
    max-width 48rem
    margin 0 auto 1rem
    text-align center
    font-size 1.875rem
    font-weight 900
    line-height 1.15
    color $white

    @media (min-width: $bp-sm)
      font-size 2.5rem

    @media (min-width: $bp-lg)
      font-size 3rem

  &__heading-accent
    color $orange

  &__subheading
    max-width 36rem
    margin 0 auto 2rem
    text-align center
    font-size 1rem
    color rgba($white, .8)

    @media (min-width: $bp-sm)
      font-size 1.125rem

  &__search
    max-width 40rem
    margin 0 auto 1.25rem

  &__search-form
    display flex
    overflow hidden
    border-radius $radius-full
    background $white
    box-shadow 0 20px 60px rgba($purple, .3)

  &__search-input
    flex 1
    background transparent
    border none
    padding .875rem 1.5rem
    font-size .875rem
    color $dark
    font-family $font-sans

    &::placeholder
      color $gray-500

    &:focus
      outline none

  &__search-btn
    display flex
    align-items center
    justify-content center
    background $cyan
    border none
    padding 0 1.5rem
    color $white
    cursor pointer
    transition background-color .2s ease

    &:hover
      background $cyan-600

  &__pills
    display flex
    flex-wrap wrap
    align-items center
    justify-content center
    gap .5rem

  &__pill-label
    font-size .875rem
    color rgba($white, .6)

  &__pill
    border-radius $radius-full
    border 1px solid rgba($white, .3)
    padding .25rem .75rem
    font-size .75rem
    font-weight 500
    color $white
    background transparent
    cursor pointer
    transition all .2s ease
    font-family $font-sans

    &:hover
      border-color $white
      background rgba($white, .1)

  // ─── Wave ───────────────────────────────────────────────────────────
  &__wave
    position absolute
    bottom -1px
    left 0
    right 0
    line-height 0

    svg
      display block
      width 100%

// ─── Stats bar ────────────────────────────────────────────────────────
.stats
  background $white
  padding 2.5rem 0

  .dark &
    background $gray-900

  &__inner
    container()

  &__grid
    display grid
    grid-template-columns repeat(2, 1fr)
    gap 1.5rem

    @media (min-width: $bp-sm)
      grid-template-columns repeat(4, 1fr)

  &__item
    display flex
    flex-direction column
    align-items center
    text-align center

  &__value
    font-size 1.5rem
    font-weight 900
    color $purple

    @media (min-width: $bp-sm)
      font-size 1.875rem

  &__label
    font-size .875rem
    color $gray-500
    margin-top .25rem

    .dark &
      color $white